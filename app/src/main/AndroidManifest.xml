<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Xelixir embedded support agent: foreground screen mirroring + notification indicator -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Trip recording (Fahrtenbuch): cell-tower tracking FGS + auto vehicle detection -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <!-- "Allow all the time" location: REQUIRED for auto-detected trips. An
         FGS-location started from the background (Activity Recognition
         IN_VEHICLE receiver) is silently denied while-in-use location on
         Android 14/15 — the provider goes `unpermitted`, fused callbacks stop
         and allCellInfo returns empty, so the whole drive records ZERO points
         (field case 2026-07-13: 27 min drive, points only appeared the moment
         the screen came on). Granted via a separate "Allow all the time"
         request AFTER fine location (Android 11+ flow). -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- Re-arm trip auto-detect after reboot (normal permission, Play-safe) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Scanner watchdog: after briefly launching the vendor scan-engine app to
         reset a hung process, move our own task back to the front (normal
         permission, Play-safe; a plain startActivity would be blocked by BAL). -->
    <uses-permission android:name="android.permission.REORDER_TASKS" />
    <!-- REQUEST_IGNORE_BATTERY_OPTIMIZATIONS is declared ONLY in the `paid`
         flavor (src/paid/AndroidManifest.xml) — Google Play restricts it, so
         the `free` (Play) build must not carry it. -->


    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- Package visibility (Android 11+): the scanner watchdog may relaunch the
         vendor scan-engine app to reset a "bad" process, so we must be able to see
         and start com.xcheng.scannere3. -->
    <queries>
        <package android:name="com.xcheng.scannere3" />
    </queries>

    <application
        android:name=".EckwmsApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EckwmsmovFast"
        android:usesCleartextTraffic="true"
        tools:targetApi="33">
        
        <!-- ML Kit automatic model download -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:label="@string/app_name"
            android:theme="@style/Theme.EckwmsmovFast"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Добавленная активность для сканера -->
        <activity
            android:name=".ScannerActivity"
            android:screenOrientation="portrait"
            android:exported="false"
            android:theme="@style/Theme.EckwmsmovFast" />

        <!-- Xelixir embedded support agent (Phase A: view-only screen mirroring).
             Consent activity is NOT exported — the only legitimate trigger is the
             server XELIXIR_START WS push (HybridMessageSender). For local bring-up
             via `adb shell am start`, temporarily flip exported="true" (DEBUG ONLY,
             do not commit). -->
        <activity
            android:name=".xelixir.XelixirConsentActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />
        <service
            android:name=".xelixir.XelixirAgentService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Phase B: input injection (taps/swipes/keys). User enables once in Settings. -->
        <service
            android:name=".xelixir.XelixirInputService"
            android:exported="false"
            android:label="@string/xelixir_a11y_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/xelixir_accessibility_config" />
        </service>

        <!-- Trip recording (Fahrtenbuch): passive cell-tower track, no GPS.
             The ongoing notification is the transparency indicator.

             The whole trip stack lives in the SMALL `:trips` process: under
             memory pressure (Google Maps + music while driving) lmkd prefers
             killing the fat UI process — a ~30 MB FGS process survives loads
             that culled the 300+ MB monolith every few minutes. EckwmsApp
             gates its init by process, so :trips never binds the scanner SDK,
             WebSocket, camera or WorkManager. -->
        <service
            android:name=".trips.TripRecordingService"
            android:exported="false"
            android:foregroundServiceType="location"
            android:process=":trips" />
        <receiver
            android:name=".trips.VehicleTransitionReceiver"
            android:exported="false"
            android:process=":trips" />
        <receiver
            android:name=".trips.BootReceiver"
            android:exported="true"
            android:process=":trips">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Room cross-process invalidation hub. Pinned to the SMALL process:
             every process using the DB binds this service, and binding spawns
             its host — hosting it in the default process would resurrect the
             heavy UI process on every :trips write, defeating the split. -->
        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            android:process=":trips"
            tools:node="merge" />
    </application>
</manifest>